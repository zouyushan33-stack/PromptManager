# Supabase public project URL.
# Configure this locally in .env.local and in Netlify environment variables.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"

# Supabase anon key. This is safe for frontend use when RLS is enabled.
# Never use or commit a service_role key in the frontend.
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
