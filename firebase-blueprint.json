{
  "entities": {
    "Prompt": {
      "title": "Prompt",
      "description": "A saved AI prompt format, shared with others.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Title of the prompt"
        },
        "content": {
          "type": "string",
          "description": "Content of the prompt"
        },
        "tags": {
          "type": "array",
          "description": "List of tags associated with the prompt"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when created"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp when last updated"
        },
        "userId": {
          "type": "string",
          "description": "The user ID who owns this prompt"
        },
        "authorName": {
          "type": "string",
          "description": "The name or email of the user who created it"
        }
      },
      "required": ["title", "content", "tags", "createdAt", "updatedAt", "userId"]
    }
  },
  "firestore": {
    "prompts/{promptId}": {
      "schema": {
        "$ref": "#/entities/Prompt"
      },
      "description": "Shared collection for all prompts"
    }
  }
}
